:root {
  --yellow: #F5C842;
  --orange: #E84C1E;
  --orange-light: #F5A87A;
  --cream: #FFF8EE;
  --white: #FFFFFF;
  --text-dark: #1A1A1A;
  --text-mid: #555;
  --text-light: #999;
  --bg-input: #FFF3D0;
  --card-bg: #FAFAFA;
  --radius: 20px;
  --radius-sm: 12px;
  --shadow: 0 4px 20px rgba(0,0,0,0.08);
  --shadow-card: 0 2px 12px rgba(232,76,30,0.12);
}

* { box-sizing: border-box; margin: 0; padding: 0; }

body {
  font-family: 'Nunito', sans-serif;
  background: #1a1a1a;
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 100vh;
  overflow: hidden;
}

.phone {
  width: 390px;
  height: 844px;
  background: var(--cream);
  border-radius: 40px;
  overflow: hidden;
  position: relative;
  box-shadow: 0 30px 80px rgba(0,0,0,0.5), inset 0 0 0 1px rgba(255,255,255,0.1);
}

.status-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14px 24px 8px;
  font-size: 12px;
  font-weight: 700;
  color: inherit;
  position: relative;
  z-index: 10;
}
.status-icons { display: flex; gap: 6px; align-items: center; }
.status-icons svg { width: 16px; height: 16px; }

.screen {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.4s ease, transform 0.4s ease;
  transform: translateX(30px);
}
.screen.active {
  opacity: 1;
  pointer-events: all;
  transform: translateX(0);
}

#splash {
  background: var(--yellow);
  justify-content: center;
  align-items: center;
}
#splash .status-bar { position: absolute; top: 0; left: 0; right: 0; color: var(--text-dark); }

.splash-logo {
  font-family: 'Pacifico', cursive;
  font-size: 42px;
  color: var(--orange);
  animation: pulse 1.5s ease-in-out infinite;
}
.splash-logo span { color: var(--text-dark); }

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50%       { transform: scale(1.05); }
}

#welcome {
  background: var(--orange);
  justify-content: flex-end;
  align-items: center;
  padding-bottom: 60px;
}
#welcome .status-bar { position: absolute; top: 0; left: 0; right: 0; color: var(--white); }

.welcome-content { text-align: center; padding: 0 40px; }

.welcome-logo {
  font-family: 'Pacifico', cursive;
  font-size: 36px;
  color: var(--white);
  margin-bottom: 16px;
}
.welcome-subtitle {
  font-size: 14px;
  color: rgba(255,255,255,0.85);
  margin-bottom: 40px;
  font-weight: 600;
}

.btn {
  display: block;
  width: 100%;
  padding: 16px;
  border-radius: 50px;
  border: none;
  font-family: 'Nunito', sans-serif;
  font-size: 16px;
  font-weight: 800;
  cursor: pointer;
  transition: transform 0.15s, box-shadow 0.15s;
}
.btn:active { transform: scale(0.97); }
.btn-primary  { background: var(--yellow); color: var(--orange); margin-bottom: 12px; }
.btn-primary:hover { box-shadow: 0 6px 20px rgba(0,0,0,0.2); }
.btn-secondary { background: var(--yellow); color: var(--orange); }
.btn-login { background: var(--orange); color: white; margin: 24px 0 16px; }

#onboarding { background: var(--cream); flex-direction: column; }
#onboarding .status-bar { color: var(--text-dark); }

.onboarding-img-placeholder {
  width: 100%;
  height: 340px;
  position: relative;
  overflow: hidden;
}

.food-big {
  position: absolute;
  inset: 0;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 120px;
}

.skip-btn {
  position: absolute;
  top: 14px;
  right: 20px;
  background: rgba(0,0,0,0.2);
  border: none;
  color: white;
  font-family: 'Nunito', sans-serif;
  font-weight: 700;
  font-size: 14px;
  padding: 6px 14px;
  border-radius: 20px;
  cursor: pointer;
  z-index: 5;
}

.onboarding-card {
  flex: 1;
  background: var(--white);
  border-radius: 28px 28px 0 0;
  margin-top: -24px;
  padding: 32px 28px 28px;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  z-index: 2;
}
.onboarding-icon  { font-size: 40px; margin-bottom: 12px; }
.onboarding-title { font-size: 22px; font-weight: 900; color: var(--orange); margin-bottom: 10px; }
.onboarding-desc  { font-size: 14px; color: var(--text-mid); line-height: 1.6; margin-bottom: 24px; }

.dots { display: flex; gap: 8px; margin-bottom: 24px; }
.dot  { width: 28px; height: 6px; border-radius: 3px; background: var(--bg-input); transition: background 0.3s; }
.dot.active { background: var(--orange); }
.dot.done   { background: var(--yellow); }

.slide-bg-0 { background: linear-gradient(160deg, #e84c1e, #f5a87a); }
.slide-bg-1 { background: linear-gradient(160deg, #c0392b, #e84c1e); }

#login  { background: var(--yellow); flex-direction: column; }
#signup { background: var(--yellow); flex-direction: column; }
#login .status-bar,
#signup .status-bar { color: var(--text-dark); }

.screen-header {
  padding: 8px 24px 20px;
  display: flex;
  align-items: center;
  gap: 12px;
}
.back-btn {
  width: 36px; height: 36px;
  border-radius: 50%;
  background: rgba(0,0,0,0.08);
  border: none;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
  color: var(--text-dark);
}
.screen-title { font-size: 22px; font-weight: 900; color: var(--text-dark); }

.form-card {
  flex: 1;
  background: var(--white);
  border-radius: 28px 28px 0 0;
  padding: 32px 24px 20px;
  overflow-y: auto;
}
.form-card::-webkit-scrollbar { display: none; }

.form-welcome { font-size: 22px; font-weight: 900; color: var(--text-dark); margin-bottom: 24px; }

.field-label { font-size: 14px; font-weight: 700; color: var(--text-dark); margin-bottom: 8px; display: block; }
.field-group  { margin-bottom: 18px; }
.input-wrap   { position: relative; }

.form-input {
  width: 100%;
  padding: 14px 16px;
  background: var(--bg-input);
  border: 2px solid transparent;
  border-radius: var(--radius-sm);
  font-family: 'Nunito', sans-serif;
  font-size: 14px;
  color: var(--text-dark);
  outline: none;
  transition: border-color 0.2s;
}
.form-input:focus { border-color: var(--orange); }
.form-input::placeholder { color: var(--text-light); }

.eye-btn {
  position: absolute;
  right: 14px;
  top: 50%;
  transform: translateY(-50%);
  background: none;
  border: none;
  cursor: pointer;
  font-size: 18px;
  color: var(--text-light);
}

.forgot-link   { text-align: right; margin-top: 6px; }
.forgot-link a { color: var(--orange); font-size: 13px; font-weight: 700; text-decoration: none; }

.or-text { text-align: center; font-size: 13px; color: var(--text-light); font-weight: 600; margin-bottom: 14px; }

.social-btns { display: flex; justify-content: center; gap: 16px; margin-bottom: 20px; }
.social-btn {
  width: 48px; height: 48px;
  border-radius: 50%;
  background: #FFF0E8;
  border: none;
  cursor: pointer;
  font-size: 22px;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.2s;
}
.social-btn:hover { background: var(--yellow); }

.register-link     { text-align: center; font-size: 13px; color: var(--text-mid); }
.register-link a   { color: var(--orange); font-weight: 700; text-decoration: none; cursor: pointer; }

.terms-text {
  font-size: 11px;
  color: var(--text-light);
  text-align: center;
  margin-bottom: 14px;
  line-height: 1.5;
}
.terms-text a { color: var(--orange); text-decoration: none; font-weight: 700; }

#home { background: var(--cream); flex-direction: column; }

.home-header {
  background: var(--yellow);
  padding: 0 20px 24px;
}
.home-top-row {
  display: flex;
  align-items: center;
  gap: 10px;
  padding-bottom: 14px;
}

.search-bar {
  flex: 1;
  display: flex;
  align-items: center;
  background: var(--white);
  border-radius: 50px;
  padding: 10px 14px;
  gap: 8px;
  box-shadow: var(--shadow);
}
.search-bar input {
  flex: 1;
  border: none;
  outline: none;
  font-family: 'Nunito', sans-serif;
  font-size: 14px;
  color: var(--text-dark);
  background: transparent;
}
.search-bar input::placeholder { color: var(--text-light); }

.filter-btn {
  background: var(--orange);
  border: none;
  border-radius: 50%;
  width: 32px; height: 32px;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
  transition: transform 0.2s;
}
.filter-btn:hover { transform: rotate(20deg); }

.icon-btn {
  width: 40px; height: 40px;
  border-radius: 50%;
  background: rgba(255,255,255,0.6);
  border: none;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
}

.home-brand    { font-family: 'Pacifico', cursive; font-size: 26px; color: var(--orange); margin-bottom: 4px; }
.home-subtitle { font-size: 13px; font-weight: 700; color: rgba(100,60,20,0.7); }

.home-body { flex: 1; overflow-y: auto; padding-bottom: 80px; }
.home-body::-webkit-scrollbar { display: none; }

.categories-row {
  display: flex;
  gap: 18px;
  padding: 20px 20px 0;
  overflow-x: auto;
}
.categories-row::-webkit-scrollbar { display: none; }

.cat-item { display: flex; flex-direction: column; align-items: center; gap: 6px; cursor: pointer; }
.cat-icon {
  width: 58px; height: 58px;
  border-radius: 50%;
  background: var(--bg-input);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26px;
  border: 2px solid transparent;
  transition: all 0.2s;
}
.cat-item.active .cat-icon,
.cat-item:hover .cat-icon { border-color: var(--orange); background: #FFF0E8; }
.cat-label { font-size: 11px; font-weight: 700; color: var(--text-mid); }

.section { padding: 20px 20px 0; }
.section-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 14px; }
.section-title  { font-size: 18px; font-weight: 900; color: var(--text-dark); }
.see-all        { font-size: 12px; font-weight: 700; color: var(--orange); text-decoration: none; }

.rest-row { display: flex; gap: 12px; overflow-x: auto; padding-bottom: 4px; }
.rest-row::-webkit-scrollbar { display: none; }

.rest-card {
  min-width: 100px; height: 100px;
  border-radius: var(--radius-sm);
  overflow: hidden;
  position: relative;
  cursor: pointer;
  flex-shrink: 0;
  transition: transform 0.2s;
}
.rest-card:hover { transform: scale(1.04); }

.rest-card-img {
  width: 100%; height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 50px;
}
.rest-card-label {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  padding: 6px;
  background: linear-gradient(transparent, rgba(0,0,0,0.65));
  color: white;
  font-size: 11px;
  font-weight: 800;
}

.promo-banner {
  margin: 20px;
  border-radius: var(--radius);
  background: linear-gradient(135deg, var(--orange) 0%, #c73a10 100%);
  padding: 20px;
  display: flex;
  gap: 12px;
  align-items: center;
  position: relative;
  overflow: hidden;
  cursor: pointer;
}
.promo-banner::after {
  content: '🍕';
  position: absolute;
  right: 12px; bottom: -8px;
  font-size: 80px;
  opacity: 0.35;
  transform: rotate(-15deg);
}
.promo-text { flex: 1; z-index: 1; }
.promo-sub  { font-size: 13px; font-weight: 700; color: rgba(255,255,255,0.85); margin-bottom: 4px; }
.promo-deal { font-size: 28px; font-weight: 900; color: white; }

.nearby-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }

.nearby-card {
  background: var(--white);
  border-radius: var(--radius-sm);
  overflow: hidden;
  box-shadow: var(--shadow);
  cursor: pointer;
  transition: transform 0.2s, box-shadow 0.2s;
}
.nearby-card:hover { transform: translateY(-2px); box-shadow: var(--shadow-card); }

.nearby-img {
  height: 110px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60px;
}
.nearby-info   { padding: 10px 10px 8px; }
.nearby-meta   { display: flex; align-items: center; justify-content: space-between; margin-bottom: 4px; }
.nearby-rating { display: flex; align-items: center; gap: 4px; font-size: 12px; font-weight: 800; color: var(--orange); }
.nearby-price  { font-size: 13px; font-weight: 800; color: var(--orange); }

.nearby-bg-0 { background: linear-gradient(160deg, #FFF0E8, #FFDDC8); }
.nearby-bg-1 { background: linear-gradient(160deg, #E8F5E9, #C8E6C9); }

#filter { background: var(--yellow); flex-direction: column; }
#filter .status-bar { color: var(--text-dark); }

.filter-card {
  flex: 1;
  background: var(--white);
  border-radius: 28px 28px 0 0;
  padding: 24px 24px 20px;
  overflow-y: auto;
}
.filter-card::-webkit-scrollbar { display: none; }

.filter-section-title { font-size: 18px; font-weight: 900; color: var(--text-dark); margin-bottom: 16px; }

.filter-cats { display: flex; gap: 14px; margin-bottom: 24px; overflow-x: auto; }
.filter-cats::-webkit-scrollbar { display: none; }

.filter-cat {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6px;
  cursor: pointer;
  flex-shrink: 0;
}
.filter-cat-icon {
  width: 54px; height: 54px;
  border-radius: 50%;
  background: var(--bg-input);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24px;
  border: 2px solid transparent;
  transition: all 0.2s;
}
.filter-cat.active .filter-cat-icon { border-color: var(--orange); background: #FFF0E8; }
.filter-cat-label { font-size: 11px; font-weight: 700; color: var(--text-mid); }

.filter-sub { font-size: 14px; font-weight: 800; color: var(--text-dark); margin-bottom: 10px; }

.stars { display: flex; gap: 4px; font-size: 22px; margin-bottom: 20px; cursor: pointer; }
.star  { transition: transform 0.1s; }
.star:hover { transform: scale(1.2); }

.chips { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 20px; }
.chip {
  padding: 7px 14px;
  border-radius: 50px;
  background: var(--bg-input);
  border: 2px solid transparent;
  font-family: 'Nunito', sans-serif;
  font-size: 13px;
  font-weight: 700;
  color: var(--text-dark);
  cursor: pointer;
  transition: all 0.2s;
}
.chip.active { background: var(--orange); color: white; border-color: var(--orange); }

.divider { height: 1px; background: #eee; margin: 0 0 20px; }

.price-section { margin-bottom: 28px; }
.price-label   { font-size: 18px; font-weight: 900; color: var(--orange); margin-bottom: 14px; }

.price-slider {
  -webkit-appearance: none;
  width: 100%;
  height: 6px;
  border-radius: 3px;
  background: linear-gradient(to right, var(--orange) 0%, var(--orange) 10%, #ddd 10%);
  outline: none;
  margin-bottom: 8px;
}
.price-slider::-webkit-slider-thumb {
  -webkit-appearance: none;
  width: 22px; height: 22px;
  border-radius: 50%;
  background: var(--orange);
  cursor: pointer;
  box-shadow: 0 2px 8px rgba(232,76,30,0.4);
}

.price-range-labels { display: flex; justify-content: space-between; font-size: 12px; font-weight: 700; color: var(--text-light); }

/* ── Filter checkbox ── */
.filter-checkbox-label {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  cursor: pointer;
  margin-bottom: 20px;
  padding: 14px;
  background: var(--bg-input);
  border-radius: var(--radius-sm);
  border: 2px solid transparent;
  transition: border-color 0.2s, background 0.2s;
}
.filter-checkbox-label.checked {
  border-color: var(--orange);
  background: #FFF0E8;
}
.filter-checkbox-box {
  width: 22px; height: 22px;
  border-radius: 6px;
  border: 2.5px solid #ccc;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
  margin-top: 1px;
}
.filter-checkbox-box.checked {
  background: var(--orange);
  border-color: var(--orange);
}
.filter-checkbox-box.checked::after {
  content: '✓';
  color: white;
  font-size: 13px;
  font-weight: 900;
}
.filter-checkbox-text {
  font-size: 13px;
  font-weight: 700;
  color: var(--text-dark);
  line-height: 1.4;
}

/* ── Filter results banner ── */
.filter-results-banner {
  display: none;
  margin: 16px 20px 0;
  padding: 10px 14px;
  background: var(--orange);
  border-radius: var(--radius-sm);
  color: white;
  font-size: 12px;
  font-weight: 700;
  align-items: center;
  justify-content: space-between;
  gap: 8px;
}
.filter-results-banner.visible { display: flex; }
.filter-clear-btn {
  background: rgba(255,255,255,0.25);
  border: none;
  color: white;
  font-family: 'Nunito', sans-serif;
  font-size: 11px;
  font-weight: 800;
  padding: 4px 10px;
  border-radius: 20px;
  cursor: pointer;
  white-space: nowrap;
}

.bottom-nav {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 72px;
  background: var(--orange);
  border-radius: 24px 24px 0 0;
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding: 0 10px 10px;
  z-index: 10;
}
.nav-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: none;
  border: none;
  cursor: pointer;
  gap: 3px;
  padding: 8px 12px;
  border-radius: 16px;
  transition: background 0.2s;
}
.nav-btn.active { background: rgba(255,255,255,0.15); }
.nav-btn:hover  { background: rgba(255,255,255,0.1); }
.nav-icon  { font-size: 22px; }
.nav-label { font-size: 9px; font-weight: 800; color: rgba(255,255,255,0.7); }
.nav-btn.active .nav-label { color: white; }

@keyframes fadeUp {
  from { opacity: 0; transform: translateY(20px); }
  to   { opacity: 1; transform: translateY(0); }
}
.animate-up { animation: fadeUp 0.5s ease forwards; }

/* ── CATEGORY SECTIONS (new) ── */
.cat-section { display: none; padding: 0 0 20px; }
.cat-section.active { display: block; }

.restaurant-list { display: flex; flex-direction: column; gap: 14px; padding: 0 20px; }

.restaurant-item {
  background: var(--white);
  border-radius: var(--radius);
  overflow: hidden;
  box-shadow: var(--shadow);
  cursor: pointer;
  transition: transform 0.2s;
}
.restaurant-item:hover { transform: scale(1.01); }

.restaurant-item-img {
  width: 100%;
  height: 130px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 70px;
}
.restaurant-item-body { padding: 12px 14px; }
.restaurant-item-name { font-size: 15px; font-weight: 900; color: var(--text-dark); margin-bottom: 4px; }
.restaurant-item-meta { display: flex; justify-content: space-between; align-items: center; }
.restaurant-item-rating { font-size: 12px; font-weight: 700; color: var(--orange); }
.restaurant-item-range  { font-size: 12px; font-weight: 700; color: var(--text-mid); }
.restaurant-item-desc { font-size: 11px; color: var(--text-light); margin-top: 4px; line-height: 1.4; }

/* ── MODAL / SIMULATE SCREEN ── */
.modal-overlay {
  position: absolute;
  inset: 0;
  background: rgba(0,0,0,0.5);
  z-index: 50;
  display: flex;
  align-items: flex-end;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s;
}
.modal-overlay.open {
  opacity: 1;
  pointer-events: all;
}
.modal-sheet {
  background: var(--white);
  border-radius: 28px 28px 0 0;
  width: 100%;
  max-height: 85%;
  overflow-y: auto;
  padding: 24px 24px 100px;
  transform: translateY(30px);
  transition: transform 0.3s;
}
.modal-sheet::-webkit-scrollbar { display: none; }
.modal-overlay.open .modal-sheet { transform: translateY(0); }

.modal-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px; }
.modal-title  { font-size: 18px; font-weight: 900; color: var(--text-dark); }
.modal-close  { background: none; border: none; font-size: 22px; cursor: pointer; color: var(--text-mid); }

.modal-rest-img {
  width: 100%;
  height: 160px;
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 80px;
  margin-bottom: 16px;
}

.modal-rating { font-size: 13px; font-weight: 700; color: var(--orange); margin-bottom: 16px; }

.sim-items { display: flex; flex-direction: column; gap: 12px; margin-bottom: 20px; }

.sim-item {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px;
  background: var(--bg-input);
  border-radius: var(--radius-sm);
}
.sim-item-emoji { font-size: 30px; }
.sim-item-info  { flex: 1; }
.sim-item-name  { font-size: 13px; font-weight: 800; color: var(--text-dark); }
.sim-item-price { font-size: 12px; font-weight: 700; color: var(--orange); }
.sim-item-qty   { display: flex; align-items: center; gap: 8px; }
.qty-btn {
  width: 28px; height: 28px;
  border-radius: 50%;
  background: var(--orange);
  color: white;
  border: none;
  font-size: 16px;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 900;
}
.qty-num { font-size: 14px; font-weight: 900; color: var(--text-dark); min-width: 16px; text-align: center; }

.sim-total {
  background: var(--bg-input);
  border-radius: var(--radius-sm);
  padding: 16px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16px;
}
.sim-total-label { font-size: 15px; font-weight: 800; color: var(--text-dark); }
.sim-total-value { font-size: 18px; font-weight: 900; color: var(--orange); }

.sim-btn {
  width: 100%;
  padding: 16px;
  border-radius: 50px;
  background: var(--orange);
  color: white;
  border: none;
  font-family: 'Nunito', sans-serif;
  font-size: 16px;
  font-weight: 800;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
}

/* ── NOTIFICATION PANEL ── */
.side-panel {
  position: absolute;
  top: 0; right: -100%;
  width: 80%;
  height: 100%;
  background: var(--white);
  z-index: 100;
  box-shadow: -4px 0 20px rgba(0,0,0,0.2);
  transition: right 0.35s cubic-bezier(.4,0,.2,1);
  display: flex;
  flex-direction: column;
  border-radius: 0 0 0 28px;
}
.side-panel.open { right: 0; }

.side-panel-overlay {
  position: absolute;
  inset: 0;
  background: rgba(0,0,0,0);
  z-index: 99;
  pointer-events: none;
  transition: background 0.35s;
}
.side-panel-overlay.open {
  background: rgba(0,0,0,0.4);
  pointer-events: all;
}

.notif-panel { right: -100%; }
.user-panel  { right: -100%; }

.panel-header {
  background: var(--orange);
  padding: 50px 20px 20px;
  border-radius: 0 0 0 24px;
}
.panel-header-title {
  font-size: 18px;
  font-weight: 900;
  color: white;
}
.panel-close {
  position: absolute;
  top: 14px;
  right: 14px;
  background: rgba(255,255,255,0.2);
  border: none;
  color: white;
  width: 32px; height: 32px;
  border-radius: 50%;
  font-size: 16px;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
}

.notif-item {
  display: flex;
  gap: 12px;
  padding: 16px 20px;
  border-bottom: 1px solid #f0f0f0;
  align-items: flex-start;
}
.notif-icon { font-size: 28px; }
.notif-text { flex: 1; }
.notif-title { font-size: 13px; font-weight: 800; color: var(--text-dark); margin-bottom: 4px; }
.notif-desc  { font-size: 12px; color: var(--text-mid); line-height: 1.4; }
.notif-time  { font-size: 10px; color: var(--text-light); font-weight: 700; }

/* ── USER PANEL ── */
.user-panel-profile {
  display: flex;
  align-items: center;
  gap: 14px;
}
.user-avatar {
  width: 56px; height: 56px;
  border-radius: 50%;
  background: var(--yellow);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28px;
  border: 3px solid white;
}
.user-panel-name  { font-size: 16px; font-weight: 900; color: white; }
.user-panel-email { font-size: 11px; color: rgba(255,255,255,0.75); }

.user-menu-list { flex: 1; padding: 10px 0; overflow-y: auto; }
.user-menu-list::-webkit-scrollbar { display: none; }

.user-menu-item {
  display: flex;
  align-items: center;
  gap: 14px;
  padding: 16px 20px;
  border-bottom: 1px solid #f5f5f5;
  cursor: pointer;
  transition: background 0.2s;
}
.user-menu-item:hover { background: #FFF8EE; }
.user-menu-item-icon {
  width: 40px; height: 40px;
  border-radius: 50%;
  background: #FFF0E8;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
}
.user-menu-item-label { font-size: 14px; font-weight: 700; color: var(--text-dark); }
.user-menu-item.danger .user-menu-item-icon { background: #FFE8E8; }
.user-menu-item.danger .user-menu-item-label { color: var(--orange); }

.user-menu-divider { height: 8px; background: #f8f8f8; margin: 8px 0; }

/* ── FAVORITES SCREEN ── */
#favorites { background: var(--cream); flex-direction: column; }

.favs-header {
  background: var(--yellow);
  padding: 0 20px 24px;
}
.favs-title {
  font-size: 22px;
  font-weight: 900;
  color: var(--orange);
  padding-top: 8px;
}

.favs-body { flex: 1; overflow-y: auto; padding: 20px 20px 90px; }
.favs-body::-webkit-scrollbar { display: none; }

.favs-section-title {
  font-size: 16px;
  font-weight: 900;
  color: var(--text-dark);
  margin-bottom: 12px;
  margin-top: 20px;
}
.favs-section-title:first-child { margin-top: 0; }

.fav-rest-card {
  background: var(--white);
  border-radius: var(--radius);
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px 14px;
  margin-bottom: 10px;
  box-shadow: var(--shadow);
  cursor: pointer;
  transition: transform 0.2s;
}
.fav-rest-card:hover { transform: scale(1.01); }
.fav-rest-emoji { font-size: 40px; }
.fav-rest-info  { flex: 1; }
.fav-rest-name  { font-size: 14px; font-weight: 900; color: var(--text-dark); }
.fav-rest-sub   { font-size: 12px; color: var(--text-light); font-weight: 600; }
.fav-heart { font-size: 18px; color: var(--orange); }

.fav-dish-row { display: flex; gap: 10px; overflow-x: auto; padding-bottom: 4px; }
.fav-dish-row::-webkit-scrollbar { display: none; }

.fav-dish-card {
  min-width: 120px;
  background: var(--white);
  border-radius: var(--radius-sm);
  overflow: hidden;
  box-shadow: var(--shadow);
  flex-shrink: 0;
  cursor: pointer;
}
.fav-dish-img {
  height: 90px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 50px;
}
.fav-dish-label {
  padding: 8px;
  font-size: 12px;
  font-weight: 800;
  color: var(--text-dark);
}
.fav-dish-price { padding: 0 8px 8px; font-size: 12px; font-weight: 700; color: var(--orange); }

/* ── SUPPORT SCREEN ── */
#support { background: var(--cream); flex-direction: column; }

.support-header {
  background: var(--orange);
  padding: 0 20px 20px;
}
.support-title {
  font-size: 20px;
  font-weight: 900;
  color: white;
  padding-top: 8px;
}
.support-sub {
  font-size: 12px;
  color: rgba(255,255,255,0.8);
  font-weight: 600;
  margin-top: 4px;
}

.chat-body {
  flex: 1;
  overflow-y: auto;
  padding: 16px 16px 0;
  display: flex;
  flex-direction: column;
  gap: 12px;
}
.chat-body::-webkit-scrollbar { display: none; }

.chat-bubble {
  max-width: 80%;
  padding: 12px 14px;
  border-radius: 18px;
  font-size: 13px;
  line-height: 1.5;
  font-weight: 600;
}
.chat-bubble.bot {
  background: var(--white);
  color: var(--text-dark);
  border-bottom-left-radius: 4px;
  align-self: flex-start;
  box-shadow: var(--shadow);
}
.chat-bubble.user {
  background: var(--orange);
  color: white;
  border-bottom-right-radius: 4px;
  align-self: flex-end;
}
.chat-time { font-size: 10px; font-weight: 700; color: var(--text-light); margin-top: 4px; }
.chat-time.right { text-align: right; }

.chat-bot-row { display: flex; gap: 8px; align-items: flex-end; }
.chat-avatar {
  width: 28px; height: 28px;
  border-radius: 50%;
  background: var(--orange);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
  flex-shrink: 0;
}

.chat-input-row {
  padding: 12px 16px;
  display: flex;
  gap: 10px;
  align-items: center;
  background: var(--white);
  border-top: 1px solid #eee;
  margin-bottom: 72px;
}
.chat-input {
  flex: 1;
  background: var(--bg-input);
  border: none;
  border-radius: 50px;
  padding: 10px 16px;
  font-family: 'Nunito', sans-serif;
  font-size: 13px;
  color: var(--text-dark);
  outline: none;
}
.chat-send-btn {
  width: 40px; height: 40px;
  border-radius: 50%;
  background: var(--orange);
  border: none;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
}
